// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuctionStatus {
  PENDING
  ACTIVE
  ENDED
}

model Card {
  id             Int      @id
  cardUrl        String?
  coverMid       String
  characterName  String?
  authorId       Int?
  authorUsername String
  titleMainName  String
  titleDir       String
  titleId        Int

  auctions Auction[]
}

model Auction {
  id         String   @id @default(cuid())
  cardId     Int
  startPrice Int?
  startTime  DateTime?
  bidTimeoutMinutes Int @default(60)
  status     AuctionStatus @default(PENDING)
  startedAt  DateTime?
  endedAt    DateTime?
  lastBidAt  DateTime?
  messageId  Int?
  currentPrice Int?
  winnerTelegramId       String?
  winnerTelegramUsername String?
  starterTelegramId       String?
  starterTelegramUsername String?
  channelId  String
  createdAt  DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id])
  bids Bid[]

  @@index([cardId])
}

model Bid {
  id                     String   @id @default(cuid())
  auctionId              String
  increment              Int
  totalPrice             Int
  bidderTelegramId       String
  bidderTelegramUsername String?
  createdAt              DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([auctionId, createdAt(sort: Desc)])
}

model ProcessedBidCallback {
  callbackId       String   @id
  auctionId        String
  bidderTelegramId String
  increment        Int
  createdAt        DateTime @default(now())

  @@index([auctionId, createdAt(sort: Desc)])
}
